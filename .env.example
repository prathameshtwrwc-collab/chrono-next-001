# =============================================================================
# CHRONOTYPE — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values.
# The app reads from .env.local at runtime.
# Do NOT commit .env.local to version control.
# =============================================================================

# --- Supabase ---
# Get these from Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here

# Required for server-side admin operations (creating orgs, members, etc.)
# This key BYPASSES RLS. Keep it server-side only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Clerk ---
# Get these from Clerk Dashboard → API Keys

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_pk_test_your_key_here
CLERK_SECRET_KEY=sk_live_or_sk_test_your_key_here

# Clerk routing configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/member
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/member

# =============================================================================
# Switching to a new Clerk/Supabase account:
#   1. Replace all 6 values above with the new account's credentials
#   2. Restart the server
#   3. No code changes needed
# =============================================================================
